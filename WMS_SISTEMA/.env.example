# =============================================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE  (copie para .env e preencha)
# =============================================================

# --- Flask / WMS ---
WMS_SECRET_KEY=troque-por-uma-chave-secreta-forte
WMS_MASTER_PASSWORD=senha_forte_aqui

# --- Telegram Bot ---
# Token obtido no @BotFather
TELEGRAM_BOT_TOKEN=0000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ID do chat/grupo onde as notificações serão enviadas
TELEGRAM_CHAT_ID=-100000000000

# --- Banco de Dados MDB ---
# Configure os caminhos do banco Access no arquivo .env real.

# --- Backend do Banco ---
# Valores aceitos: access | mysql
WMS_DB_BACKEND=access

# --- Banco de Dados Access (legado) ---
# WMS_MDB_PATH_PROD=C:\caminho\wms_database.mdb
# WMS_MDB_PATH_TEST=C:\caminho\wms_database_test.mdb

# --- Banco de Dados MySQL ---
# Produção
# WMS_MYSQL_HOST_PROD=127.0.0.1
# WMS_MYSQL_PORT_PROD=3306
# WMS_MYSQL_USER_PROD=root
# WMS_MYSQL_PASSWORD_PROD=senha_aqui
# WMS_MYSQL_DATABASE_PROD=wms

# Teste
# WMS_MYSQL_HOST_TEST=127.0.0.1
# WMS_MYSQL_PORT_TEST=3306
# WMS_MYSQL_USER_TEST=root
# WMS_MYSQL_PASSWORD_TEST=senha_aqui
# WMS_MYSQL_DATABASE_TEST=wms_test
